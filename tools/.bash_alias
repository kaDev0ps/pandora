# ============================================================
#  .bash_aliases – clean, safe, no duplicates, no auto-welcome
# ============================================================

# ---------- Basic commands ----------
alias up='uptime -p'
alias scat='sudo cat -n'
alias tails='tail -n +1'
alias c='clear'
alias ipa='ip -br -c a'
alias ll='ls -lh'
alias lo='locate'
alias df='df -h'
alias ..='cd ..'
alias lsd='lsd -lh --icon=never'
alias la='ls -lah --color=auto'
alias lscpu='sudo lscpu'
alias mkdir='mkdir -pv'
alias delta='sudo delta --side-by-side --line-numbers --dark --navigate --syntax-theme="Nord" --width=-2'
alias svim='sudo vim'
alias psg='ps aux | grep'
alias vs='sudo visudo'
alias r='ranger'
alias sr='sudo ranger'
alias del='sudo rm -rf'
alias duse='du -ah --max-depth=1 $(pwd) | sort -rh | head -n 10'
alias dlog='du -sh /var/log/* 2>/dev/null | sort -hr | head -n 10'
alias ncdu='sudo ncdu'
alias lsof='sudo lsof -i'
alias gr="grep -Ev '^\s*#|^$'"
alias col='column -t -s'
alias cutc='cut -c'
alias killu='sudo pkill -9 -u'

# ---------- Updates & system info ----------
alias mtr10='mtr -r -c 10'
alias mtr100='mtr -r -c 100'
alias sysinfo='uname -a; lsb_release -a'
alias update='sudo apt update'
alias clean='sudo apt clean'
alias autoremove='sudo apt autoremove -y'

# ---------- Monitoring ----------
alias h='history'
alias j='jobs -l'
alias du='du -ch'
alias ports='sudo ss -tulnp'
alias myip='curl ifconfig.me'

# ---------- Networking ----------
alias dnstop='sudo dnstop -l 5'
alias vnstat='sudo vnstat -i'
alias iftop='sudo iftop -i'
alias tcpdump='sudo tcpdump -i'
alias open='sudo nmap -sUT -p- localhost'

# ---------- Systemctl ----------
alias sss='sudo systemctl stop'
alias ssr='sudo systemctl restart'
alias sse='sudo systemctl enable'
alias ssd='sudo systemctl disable'
alias ssc='sudo systemctl cat'
alias ssi='sudo systemctl status'
alias slu='sudo systemctl list-units --type=service'
alias sdr='sudo systemctl daemon-reload'
alias srr='sudo systemctl reset-failed'
alias edit='sudo systemctl edit'
alias scg='systemd-cgtop -d 5'

# ---------- Journalctl ----------
alias logs='sudo journalctl -xe'
alias jfeu='sudo journalctl -n 20 -feu'
alias clearlogs='sudo journalctl --vacuum-time=1d'

# ---------- Archiving ----------
alias taz='tar -czvf'
alias untaz='tar -xzvf'

# ---------- Tools ----------
alias iot='sudo iotop -oPa'
alias ios='iostat -mpxz'
alias pssh="parallel-ssh"
alias pssc="parallel-scp"
alias fd="fdfind"

# ---------- GIT ----------
alias gitp='gitc && git push'

# ---------- Load Balancer ----------
alias nt='sudo nginx -t'
alias at='sudo angie -t'
alias srn='sudo systemctl reload nginx'
alias sra='sudo systemctl reload angie'

# ---------- Environment ----------
alias envr="source ~/ranger-env/bin/activate"
alias envs="deactivate"

# ---------- Exports ----------
export HISTTIMEFORMAT="%d.%m.20%y %T "
export EDITOR=vim
export HIST_STAMPS="%F %T"

# ---------- Docker ----------
alias adduserd='sudo usermod -aG docker $USER'
alias d='docker'
alias dps='docker ps'
alias dpa='docker ps -a'
alias dpsq='docker ps -q'
alias dls='docker ps -l -q'
alias di='docker images -a'
alias diq='docker images -q'
alias dins='docker inspect'
alias diins='docker image inspect'
alias dv='docker version'
alias dinfo='docker system info'
alias ddf='docker system df'
alias dstats='docker stats'
alias devents='docker system events'
alias ddisk='df -h /var/lib/docker'
alias ddaemon='cat /etc/docker/daemon.json'
alias djfeuc='sudo journalctl -feu containerd'
alias djfeud='sudo journalctl -feu docker'

alias db='docker build -t'
alias dbc='docker build --no-cache -t'
alias dbf='docker build -f -t'
alias dph='docker pull'
alias drs='docker search'
alias dih='docker image history'
alias drmi='docker rmi'

alias drun='docker run -it --rm'
alias drund='docker run -d --rm'
alias drp='docker run -d -p --rm'
alias drP='docker run -d -P --rm'
alias dexec='docker exec -it'
alias dsh='docker exec -it $(docker ps -lq) sh || docker exec -it $(docker ps -lq) bash'
alias datt='docker attach'

alias dlogs='docker logs -f --tail 100'
alias dstop='docker stop'
alias dkill='docker kill'
alias drst='docker restart'
alias dstart='docker start'
alias drm='docker rm -f'
alias drename='docker rename'
alias dcp='docker cp'

alias dcpr='docker container prune -f'
alias dipr='docker image prune -a -f'
alias dvpr='docker volume prune -f'
alias dnpr='docker network prune -f'
alias dbpr='docker builder prune -a -f'
alias dspr='docker system prune -a -f'
alias dsprv='docker system prune -a -f --volumes'

alias dvl='docker volume ls'
alias dvins='docker volume inspect'
alias dvcr='docker volume create'
alias dvrm='docker volume rm'

alias dc='docker compose'
alias dcu='docker compose up -d'
alias dcub='docker compose up -d --build'
alias dcd='docker compose down -v'
alias dcl='docker compose logs -f'
alias dcp='docker compose ps'
alias dce='docker compose exec'
alias dcb='docker compose build'
alias dcrm='docker compose rm -f'
alias dcfg='docker compose config'

alias dsi='docker swarm init'
alias dsjw='docker swarm join-token worker'
alias dsjm='docker swarm join-token manager'
alias dsnl='docker node ls'
alias dsls='docker service ls'
alias dsdeploy='docker stack deploy --compose-file'
alias dsrm='docker stack rm'
alias dstls='docker stack ls'
alias dsservices='docker stack services'
alias dsps='docker stack ps'
alias dslogs='docker service logs'
alias dsconfig='docker stack config'

# ---------- K8s / Minikube ----------
alias mks='minikube status'
alias mkr='minikube start'
alias mksvc='minikube service'

alias kgno='kubectl get nodes'
alias kgpo='kubectl get pods'
alias kgall='kubectl get all'
alias kgs='kubectl get service'
alias kgrs='kubectl get replicaset'
alias kge='kubectl get endpoints'
alias kgallp='kubectl get po -A'

alias kdpo='kubectl describe pod'
alias kdse='kubectl describe service'
alias kdrs='kubectl describe rs'
alias kddp='kubectl describe deploy'
alias kdn='kubectl describe node'
alias kl='kubectl logs'
alias klf='kubectl logs -f'

alias kdelpo='kubectl delete pod'
alias kdelrs='kubectl delete rs'
alias kdeldp='kubectl delete deploy'
alias kdels='kubectl delete service'

alias krstatus='kubectl rollout status deploy'
alias krhistory='kubectl rollout history'
alias krundo='kubectl rollout undo'

alias kci='kubectl cluster-info'
alias kr='kubectl run'
alias kcf='kubectl create -f'
alias kaf='kubectl apply -f'
alias krrs='kubectl replace replicaset -f'
alias kers='kubectl edit replicaset'
alias kadry='kubectl apply --dry-run=client -f'

alias ktop='kubectl top'
alias ktopn='kubectl top node'
alias ktopp='kubectl top pod'

# ---------- NEW: stat alias (run welcome + full config) ----------
alias stat='~/tools/welcome.sh'

# ---------- Functions ----------
gitc() {
  git add . && git commit -m "$(date '+%Y-%m-%d %H:%M:%S')" || echo "Git commit failed"
}

info() {
  echo "USER PID %CPU %MEM COMMAND"
  sudo ps -eo user,pid,%cpu,%mem,command --no-headers | sort -nr -k 3 | head -10
}

connections() {
  ss -tan | awk '/ESTAB/ {print $5}' | cut -d: -f1 | sort | uniq -c | sort -nr | head -10
}

n3() {
  for unit in $(systemctl list-unit-files "r*.service" --type=service --no-legend | awk '{print $1}'); do
    port=$(systemctl show "$unit" --property=Environment | grep -oP '(?<=:)\d+')
    [[ -n "$port" ]] && echo "$port $unit"
  done
}

ssv() {
  sudo vim "/etc/systemd/system/${1}"
}
